<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 280" width="320" height="280" role="img" aria-label="The Open CDR Project — light">
  <title>The Open CDR Project</title>
  <desc>Light variant — The Open CDR Project.</desc>

  <defs>
    <radialGradient id="apex-glow-l" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#F59E0B" stop-opacity="0.16"/>
      <stop offset="100%" stop-color="#F59E0B" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Background — pure white -->
  <rect width="320" height="280" fill="#FFFFFF"/>

  <!-- ── LATTICE ICON ── -->
  <g transform="translate(128, 58) scale(0.889)">
    <circle cx="36" cy="10" r="22" fill="url(#apex-glow-l)"/>

    <line x1="36"  y1="15"   x2="13.5" y2="34.5" stroke="#1A56A0" stroke-width="1.6" stroke-opacity="0.4"  stroke-linecap="round"/>
    <line x1="36"  y1="15"   x2="58.5" y2="34.5" stroke="#1A56A0" stroke-width="1.6" stroke-opacity="0.4"  stroke-linecap="round"/>
    <line x1="16.5" y1="38.5" x2="33"  y2="43.5" stroke="#2E7FD4" stroke-width="1.3" stroke-opacity="0.34" stroke-linecap="round"/>
    <line x1="55.5" y1="38.5" x2="39"  y2="43.5" stroke="#2E7FD4" stroke-width="1.3" stroke-opacity="0.34" stroke-linecap="round"/>
    <line x1="16.5" y1="38"   x2="55.5" y2="38"  stroke="#2E7FD4" stroke-width="1"   stroke-opacity="0.22" stroke-dasharray="3 3" stroke-linecap="round"/>

    <circle cx="36" cy="10" r="6.5" fill="#F59E0B"/>
    <circle cx="12" cy="38" r="5.5" fill="#1A56A0"/>
    <circle cx="36" cy="46" r="5.5" fill="#2E7FD4"/>
    <circle cx="60" cy="38" r="5.5" fill="#1A56A0"/>
  </g>

  <!-- ── WORDMARK ── -->
  <!-- "THE" -->
  <text
    x="160" y="136"
    font-family="'Unbounded', sans-serif"
    font-weight="400"
    font-size="8.5"
    letter-spacing="4"
    text-anchor="middle"
    fill="rgba(13,27,62,0.55)"
  >THE</text>

  <!-- "Open CDR" -->
  <text
    x="160" y="183"
    font-family="'Unbounded', sans-serif"
    font-weight="700"
    font-size="44"
    text-anchor="middle"
  >
    <tspan letter-spacing="-1.2" fill="#0D1B3E">Open </tspan><tspan letter-spacing="-1.2" fill="#1A56A0">CDR</tspan>
  </text>

  <!-- "PROJECT" -->
  <text
    x="160" y="205"
    font-family="'JetBrains Mono', monospace"
    font-weight="400"
    font-size="8.5"
    letter-spacing="4"
    text-anchor="middle"
    fill="rgba(13,27,62,0.5)"
  >PROJECT</text>

</svg>
